# Database (Supabase pooler IPv4-safe)
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?sslmode=require

# App
PORT=5000

# Optional execution provider (defaults to jdoodle)
EXECUTION_PROVIDER=jdoodle
JDOODLE_CLIENT_ID=your_jdoodle_client_id
JDOODLE_CLIENT_SECRET=your_jdoodle_client_secret

# AI provider key
OPENROUTER_API_KEY=your_openrouter_api_key
